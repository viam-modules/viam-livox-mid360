{
  "module_id": "evan:livox-mid360",
  "visibility": "public",
  "url": "https://github.com/viamrobotics/livox-mid-360",
  "description": "Viam module for the Livox Mid-360 LiDAR (camera + IMU)",
  "models": [
    {
      "api": "rdk:component:camera",
      "model": "viam:livox:mid360"
    },
    {
      "api": "rdk:component:movement_sensor",
      "model": "viam:livox:mid360-imu"
    }
  ],
  "entrypoint": "livox-mid-360",
  "build": {
    "setup": "sudo apt-get update && sudo apt-get install -y cmake build-essential && git submodule update --init --recursive",
    "build": "make module",
    "path": "module.tar.gz",
    "arch": ["linux/amd64", "linux/arm64"]
  }
}
